@model GenericListOutput<BasinTakip.Domain.Entities.Base.Vehicle, int>

@{
    ViewBag.Title = "Test Araçları Kaydı Listeleme";
    ViewBag.BackClass = "viewbag_Back";
    ViewBag.button = "btn-add";
    ViewBag.btnNew = "/Vehicle/Detail";
    Layout = "~/Views/Shared/_ListLayout.cshtml";
    <style>
        .TestYear{
                width: 170px!important;
        }
    </style>
}
<div class="box box-block bg-white">
    <div class="dataTables_wrapper form-inline dt-bootstrap4">
        <div class="row" style="background-color:#212330; height:85px;margin-top: -16px; color:#fff;">
            <form method="get" action="@Url.Action("List","Vehicle")" class="col-lg-12 filtreleme  filtreleme-Vehicle">
                <div class="col-lg-2" style="padding: 19px 0px 0;">
                    <i class="fa fa-search" aria-hidden="true"> </i>  <input type="text" name="SearchText" value="" style="background-color: #212330;color:#fff;" placeholder="Arama" />
                </div>
                <div class="col-lg-1 form-controls">
                    <h5>Filtreleme</h5>
                </div>

                <div class="col-lg-2 form-controls">
                    <div>
                        <h4 style="width:100%;">Model Yılı </h4>
                    </div>
                    <div>
                        <select name="ModelYear" class="TestYear">
                            <option value=""> Model Yılı</option>
                            <option value="2015">2015</option>
                            <option value="2016">2016</option>
                            <option value="2017">2017</option>
                            <option value="2018">2018</option>
                            <option value="2019">2019</option>
                            <option value="2020">2020</option>
                        </select>
                    </div>
                </div>
                
                <div class="col-lg-1" >
                    <button class="btn" type="submit">Uygula </button>
                </div>
            </form>
            <input type="hidden" name="QueryString" value="@ViewBag.QueryString" />
        </div>
        <div class="row">
            <a href="/Export/VehicleReport" class="btn btn-danger label-left btn-export btn-export-vehicle">
                <span class="btn-label"><i class="ti-download"></i></span>
                Excele Aktar
            </a>
        </div>
        <div class="row">
            <div class="col-md-12">
                <table class="table table-striped mb-md-0">
                    <thead>
                        <tr>
                            <th></th>
                            <th><a href="#" class="orderby-btn" data-orderbycolumn="Marka">Marka</a></th>
                            <th><a href="#" class="orderby-btn" data-orderbycolumn="Serial">Seri</a></th>
                            <th><a href="#" class="orderby-btn" data-orderbycolumn="Model">Model</a></th>
                            <th><a href="#" class="orderby-btn" data-orderbycolumn="Plate">Plaka</a></th>
                            <th><a href="#" class="orderby-btn" data-orderbycolumn="ModelDate">Model Yılı</a></th>
                            <th>#</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.PagedData.Count; i++)
                        {
                            var item = Model.PagedData[i];

                            <tr>
                                <th scope="row">@(i + 1)</th>
                                <td>@Html.ActionLink(item.Marka, "Detail", new { id = item.Id })</td>
                                <td>@Html.ActionLink(item.Serial, "Detail", new { id = item.Id })</td>
                                <td>@Html.ActionLink(item.Model, "Detail", new { id = item.Id })</td>
                                <td>@Html.ActionLink(item.Plate, "Detail", new { id = item.Id })</td>
                                <td>@Html.ActionLink(item.ModelDate, "Detail", new { id = item.Id })</td>
                                <td>@Html.ActionLink("Sil", "Delete", new { id = item.Id }, new { @class = "delete", onclick = "return confirm('Test araç kaydını silmek istediğinizden emin misiniz?');" })</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="row">
            <div class="col-md-5">
                <div class="dataTables_info">
                    @Model.PagedData.TotalItemCount Sonuçtan @(Model.PagedData.PageCount <= 0 ?
                    0 : 1) ile @Model.PagedData.Count() arası gösteriliyor
                </div>
            </div>
            <div class="col-md-7">
                <div class="dataTables_paginate paging_simple_numbers">
                    @Html.PagedListPager(Model.PagedData, pageNumber => Url.Action("List", new { pageNumber }))
                </div>
            </div>
        </div>
    </div>
</div>