@model GenericListOutput<PersonResult, int>

@{
    ViewBag.Title = "Basın Mensubu Listeleme";
    Layout = "~/Views/Shared/_ListLayout.cshtml";
}
<div class="box box-block bg-white">
    <div class="dataTables_wrapper form-inline dt-bootstrap4">
        <div class="row" style="background-color:#212330; height:85px;margin-top: -16px; color:#fff;">
            @*<div class="col-lg-2">
                <a href="/Person/List?Block=True" class="@ViewBag.btnBlockFilter">Kara Liste</a>
                <a href="/Person/List?Block=False" class="@ViewBag.btnBlockAll">Hepsi</a>
            </div>*@
            <form method="get" action="@Url.Action("List","Person")" class="col-lg-12 filtreleme filtreleme-Press">
               
                <div class="col-lg-2 form-controls" style="padding: 16px 4px 0 0;">
                    <div style="">
                        <a href="/Person/List?Block=True" class="@ViewBag.btnBlockFilter block-style .block-control-true">Kara Liste</a>
                        <a href="/Person/List?Block=False" class="@ViewBag.btnBlockAll block-style .block-control-false">Hepsi</a>
                    </div>
                   
                    <input type="hidden" name="Block" value="@ViewBag.Blocks" />
                </div>
                <div class="col-lg-1 form-controls">
                    <h5>Filtreleme</h5> 
                </div>
                <div class="col-lg-2 form-controls">
                    <div>
                        <h4 style="width:100%;">İletişim Kurulan </h4>
                    </div>
                    <div>
                        <select name="BeginYear">
                            <option value="">Yıl</option>
                            <option @Html.Raw(Model.filter[0] == "2017" ? "selected" : "") value="2017">2017</option>
                            <option @Html.Raw(Model.filter[0] == "2018" ? "selected" : "") value="2018">2018</option>
                            <option @Html.Raw(Model.filter[0] == "2019" ? "selected" : "") value="2019">2019</option>
                            <option @Html.Raw(Model.filter[0] == "2020" ? "selected" : "") value="2020">2020</option>
                        </select>
                        <select name="BeginMonth">
                            <option value="">Ay</option>
                            <option @Html.Raw(Model.filter[1] == "1" ? "selected" : "") value="01">Ocak</option>
                            <option @Html.Raw(Model.filter[1] == "2" ? "selected" : "") value="02">Şubat</option>
                            <option @Html.Raw(Model.filter[1] == "3" ? "selected" : "") value="03">Mart</option>
                            <option @Html.Raw(Model.filter[1] == "4" ? "selected" : "") value="04">Nisan</option>
                            <option @Html.Raw(Model.filter[1] == "5" ? "selected" : "") value="05">Mayıs</option>
                            <option @Html.Raw(Model.filter[1] == "6" ? "selected" : "") value="06">Haziran</option>
                            <option @Html.Raw(Model.filter[1] == "7" ? "selected" : "") value="07">Temmuz</option>
                            <option @Html.Raw(Model.filter[1] == "8" ? "selected" : "") value="08">Ağustos</option>
                            <option @Html.Raw(Model.filter[1] == "9" ? "selected" : "") value="09">Eylül</option>
                            <option @Html.Raw(Model.filter[1] == "10" ? "selected" : "") value="10">Ekim</option>
                            <option @Html.Raw(Model.filter[1] == "11" ? "selected" : "") value="11">Kasım</option>
                            <option @Html.Raw(Model.filter[1] == "12" ? "selected" : "") value="12">Aralık</option>
                        </select>
                    </div>
                </div>
                <div class="col-lg-2 form-controls">
                    <div>
                        <h4>İl </h4>
                        <h4 style="margin-left:44%;">İlçe </h4>
                    </div>
                    <div class="district-control">
                        <select name="CityId" class="countrySelect" >
                            <option value="">İl</option>
                            @foreach (var item in ViewBag.CityList)
                            {
                                <option @Html.Raw(Model.filter[2]==item.Id.ToString()?"Selected":"") value="@item.Id">@item.Name </option>

                            }
                        </select>
                        <input type="hidden" class="hiddenDistrict"  value="@Model.filter[3]" />
                        <select name="DistrictId" id="DistrictId"  dataUrl="/api/common/getDistrictList" dependedElement = "#CountryId">
                            <option value="" >İlçe</option>
                        </select>
                    </div>
                  
                    
                </div>
                <div class="col-lg-2 form-controls">
                    <div>
                        <h4 style="width:100%;">Yayın </h4>
                    </div>
                    <div>
                        <select name="Edition">
                            <option value="">Yayın </option>
                            @foreach (var item in ViewBag.EditionList)
                            {
                                <option @Html.Raw(Model.filter[4]==item.Id.ToString()?"Selected":"") value="@item.Id">@item.Name </option>

                            }
                        </select>
                    </div>
                </div>
                <div class="col-lg-2 form-controls">
                    <div>
                        <h4 style="width:100%;">Görev Bilgileri  </h4>
                    </div>
                    <div>
                        <select name="TaskId">
                            <option value="">Görev Bilgileri</option>
                            @foreach (var item in ViewBag.TaskList)
                            {
                                <option @Html.Raw(Model.filter[5]==item.Id.ToString()?"Selected":"") value="@item.Id">@item.Name </option>

                            }
                        </select>
                    </div>
                </div>
                <div class="col-lg-1" style="float:right;">
                    <button class="btn btn-formsubmit" type="submit">Uygula </button>
                </div>
                <div class="row">
                    <div class="col-lg-12" style="padding: 35px 0 0 0;">
                        <i class="fa fa-search" aria-hidden="true" style="color:#212330;"> </i>  <input type="text" name="SearchText" value="@Model.filter[6]" placeholder="Arama" />
                    </div>
                </div>
              

                <input type="hidden" name="QueryString" value="@ViewBag.QueryString" />
            </form>

            <a href="/Export/PressMemberReport?@ViewBag.QueryString" class="btn btn-danger label-left btn-export">
                <span class="btn-label"><i class="ti-download"></i></span>
                Excele Aktar
            </a>

        </div>
        <div class="row">
            <div class="col-md-12">
                <table class="table table-striped table-bordered mb-md-0 dataTable" id="table-1" aria-describedby="table-1_info">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th><a href="#" class="orderby-btn" data-orderbycolumn="Adsoyad">Ad Soyad</a></th>
                            <th><a href="#" class="orderby-btn" data-orderbycolumn="MobilePhone">Cep Telefonu</a></th>
                            <th><a href="#" class="orderby-btn" data-orderbycolumn="Email">Email Adresi</a></th>
                            <th><a href="#" class="orderby-btn" data-orderbycolumn="TaskName">Görev Bilgileri</a></th>
                            <th><a href="#" class="orderby-btn" data-orderbycolumn="EditionName">Yayın</a></th>
                            <th><a href="#" class="orderby-btn" data-orderbycolumn="CreatedAt">Kayıt Tarihi</a></th>
                            <th>#</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.PagedData.Count; i++)
                        {
                            var item = Model.PagedData[i];

                            <tr>
                                <th scope="row">@(i + 1)</th>
                                <td>@Html.ActionLink(item.Adsoyad, "Detail", new { id = item.Id })</td>
                                <td>@Html.ActionLink(item.MobilePhone, "Detail", new { id = item.Id })</td>
                                <td>@Html.ActionLink(item.Email, "Detail", new { id = item.Id })</td>
                                <td>@Html.ActionLink(item.TaskName, "Detail", new { id = item.Id })</td>
                                <td>@Html.ActionLink(item.EditionName, "Detail", new { id = item.Id })</td>
                                <td>@Html.ActionLink(item.CreatedAt.ToString("dd/MM/yyyy"), "Detail", new { id = item.Id })</td>
                                <td>@Html.ActionLink("Sil", "Delete", new { id = item.Id },new { @class="delete", onclick = "return confirm('Basın üyesini silmek istediğinizden emin misiniz?');" })</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="row">
            <div class="col-md-5">
                <div class="dataTables_info">
                    @Model.PagedData.TotalItemCount Sonuçtan @(Model.PagedData.PageCount <= 0 ?
                    0 : 1) ile @Model.PagedData.Count() arası gösteriliyor
                </div>
            </div>
            <div class="col-md-7">
                <div class="dataTables_paginate paging_simple_numbers">
                    @Html.PagedListPager(Model.PagedData, pageNumber => Url.Action("List", new { pageNumber, BeginYear = Model.filter[0], BeginMonth = Model.filter[1], CityId = Model.filter[2], DistrictId = Model.filter[3], Edition = Model.filter[4], TaskId = Model.filter[5], SearchText = Model.filter[6], Block=Model.filter[7], orderByColumn=Model.filter[8], OrderType=Model.filter[9]}))
                </div>
            </div>
        </div>
    </div>
</div>